# Mini-program API base. From request URL host:
# POST https://api.x.zanao.com/thread/v2/list
ZANAO_BASE_URL=https://api.x.zanao.com

# From request header: X-Sc-Alias
ZANAO_SCHOOL_ALIAS=

# From request header: X-Sc-Od
# Sensitive. Do not commit your real value.
ZANAO_USER_TOKEN=

# Used to generate X-Sc-Ah.
# If unknown, leave empty for now. We will verify signing separately.
ZANAO_API_SALT=

# From request header: X-Sc-Version
ZANAO_SC_VERSION=

# From request header: X-Sc-Platform
ZANAO_SC_PLATFORM=

# From request header: X-Sc-Appid
ZANAO_SC_APPID=

# From request header: User-Agent
ZANAO_USER_AGENT=

# From request header: Referer
ZANAO_REFERER=

# Optional Feishu bot config for later real sending.
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=

# Optional AstrBot webhook notification.
ASTRBOT_ENABLED=false
ASTRBOT_WEBHOOK_URL=
ASTRBOT_TOKEN=
ASTRBOT_TIMEOUT_SECONDS=10

# Optional AI second-pass review. Disabled by default.
# Supports OpenAI-compatible chat completions APIs.
AI_ENABLED=false
AI_PROVIDER=openai-compatible
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_CONFIDENCE_THRESHOLD=0.7
AI_TIMEOUT_SECONDS=10
